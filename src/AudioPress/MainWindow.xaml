<Window x:Class="AudioPress.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AudioPress 音频批量压缩器"
        Icon="Assets/AudioPress.ico"
        Width="1180"
        Height="780"
        MinWidth="980"
        MinHeight="660"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Closing="Window_Closing">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="150" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="AudioPress" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="本地批量压缩、提取和转换音频文件" Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,0" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="添加文件" Command="{Binding AddFilesCommand}" />
                <Button Content="添加文件夹" Command="{Binding AddFolderCommand}" />
                <Button Content="清空队列" Command="{Binding ClearCommand}" />
                <Button Content="重试失败" Command="{Binding RetryFailedCommand}" />
                <Button Content="{Binding StartButtonText}" Command="{Binding StartCommand}" Style="{StaticResource PrimaryButton}" />
                <Button Content="全部取消" Command="{Binding CancelAllCommand}" />
            </StackPanel>
        </DockPanel>

        <GroupBox Grid.Row="1" Header="{Binding SettingsHeader}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,10">
                    <TextBlock Text="处理模式" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding ProcessingModes}"
                              SelectedItem="{Binding SelectedProcessingMode}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,10">
                    <TextBlock Text="预设" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding Presets}"
                              SelectedItem="{Binding SelectedPreset}"
                              DisplayMemberPath="Name"
                              Margin="0,6,0,0" />
                    <TextBlock Text="{Binding SelectedPresetDescription}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,12,10">
                    <TextBlock Text="输出格式" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding OutputFormats}"
                              SelectedItem="{Binding SelectedOutputFormat}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,12,10">
                    <TextBlock Text="同名文件" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding SameNamePolicies}"
                              SelectedItem="{Binding SelectedSameNamePolicy}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,10">
                    <TextBlock Text="输出位置" FontWeight="SemiBold" />
                    <CheckBox Content="{Binding SourceFolderLabel}"
                              IsChecked="{Binding UseSourceCompressedFolder}"
                              Margin="0,8,0,4" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="选择" Command="{Binding BrowseOutputCommand}" IsEnabled="{Binding CanChooseOutputDirectory}" Margin="8,0,0,0" />
                        <TextBox Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanChooseOutputDirectory}" />
                    </DockPanel>
                </StackPanel>

                <UniformGrid Grid.Row="1" Grid.ColumnSpan="5" Columns="6" Margin="0,0,0,8">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="码率 kbps" />
                        <ComboBox ItemsSource="{Binding BitrateOptions}"
                                  Text="{Binding BitrateKbps, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="采样率 Hz" />
                        <TextBox Text="{Binding SampleRateHz, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="声道" />
                        <TextBox Text="{Binding Channels, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="VBR质量" />
                        <TextBox Text="{Binding VbrQuality, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="FLAC等级" />
                        <TextBox Text="{Binding FlacCompressionLevel, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="WAV位深" />
                        <TextBox Text="{Binding WavBitDepth, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="5" Orientation="Horizontal">
                    <CheckBox Content="保留标题、艺术家、专辑等元数据"
                              IsChecked="{Binding PreserveMetadata}"
                              Margin="0,0,24,0" />
                    <CheckBox Content="尽可能保留封面"
                              IsChecked="{Binding PreserveCoverArt}"
                              Margin="0,0,24,0" />
                    <CheckBox Content="添加文件夹时递归扫描"
                              IsChecked="{Binding RecursiveFolderScan}" />
                    <TextBlock Text="{Binding EstimatedOutputSizeText}"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontWeight="SemiBold"
                               Margin="24,2,0,0" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Jobs}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeight="42"
                  Background="White"
                  BorderBrush="{StaticResource BorderBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="190" />
                <DataGridTextColumn Header="输入路径" Binding="{Binding InputPath}" Width="*" />
                <DataGridTextColumn Header="输出路径" Binding="{Binding OutputPath}" Width="*" />
                <DataGridTextColumn Header="编码" Binding="{Binding CodecText}" Width="90" />
                <DataGridTextColumn Header="时长" Binding="{Binding DurationText}" Width="76" />
                <DataGridTextColumn Header="大小" Binding="{Binding SizeText}" Width="86" />
                <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="76" />
                <DataGridTemplateColumn Header="进度" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="42" />
                                </Grid.ColumnDefinitions>
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" Height="12" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding ProgressText}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="信息" Binding="{Binding Message}" Width="220" />
                <DataGridTemplateColumn Header="操作" Width="76">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="取消" Command="{Binding CancelCommand}" IsEnabled="{Binding CanCancel}" Margin="0" Padding="8,4" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="3" Header="日志" Margin="0,12,0,0">
            <TextBox Text="{Binding LogText, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas, Microsoft YaHei UI"
                     BorderThickness="0" />
        </GroupBox>

        <DockPanel Grid.Row="4" Margin="0,10,0,0">
            <TextBlock DockPanel.Dock="Left" Text="{Binding StatusLine}" Foreground="{StaticResource MutedTextBrush}" />
            <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedTextBrush}">
                <Run Text="已结束 " />
                <Run Text="{Binding FinishedCount, Mode=OneWay}" />
                <Run Text=" / " />
                <Run Text="{Binding TotalCount, Mode=OneWay}" />
            </TextBlock>
        </DockPanel>
    </Grid>
</Window>
