<Application x:Class="AudioPress.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F5F7FA" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D8DEE8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#115E59" />
        <SolidColorBrush x:Key="TextBrush" Color="#172033" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5D6B82" />

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
            <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="6,2" />
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Application.Resources>
</Application>

